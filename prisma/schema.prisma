generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  ADMIN
  VIEWER
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  projects    Project[]
  invitations Invitation[]
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  fullName         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  memberships      Membership[]
  viewableProjects Project[]         @relation("ProjectViewers")
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           MemberRole
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           MemberRole
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  token          String       @unique
  accepted       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String
  projectType           String?
  location              String?
  plannedDurationDays   Int?
  goalSummary           String
  projectPlanFileName   String?
  projectPlanMimeType   String?
  projectPlanFileData   Bytes?
  projectPlanUploadedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  reports               Report[]
  viewers               User[]       @relation("ProjectViewers")
  invitations           Invitation[]

  @@unique([organizationId, name])
}

model Report {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date               DateTime @db.Date
  summary            String?
  workersOnSite      Int      @default(0)
  plannedProgressPct Int?
  actualProgressPct  Int?
  completionPct      Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  workItems          ReportWorkItem[]

  @@index([date])
  @@unique([projectId, date])
}

model ReportWorkItem {
  id              String @id @default(cuid())
  reportId        String
  report          Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  contractor      String
  workDescription String
  engineerName    String
  location        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportId])
}
