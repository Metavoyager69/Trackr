generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  memberships  Membership[]
  projects     Project[]
  invitations  Invitation[]
  activityLogs ActivityLog[]
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  passwordHash     String
  fullName         String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  memberships      Membership[]
  activityLogs     ActivityLog[]
  viewableProjects Project[]     @relation("ProjectViewers")
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       // "ADMIN" or "VIEWER"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       // "ADMIN" or "VIEWER"
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  token          String       @unique
  accepted       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName       String
  action         String
  details        String?
  createdAt      DateTime     @default(now())
}

model Project {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String   @unique
  projectType           String?
  location              String?
  plannedDurationDays   Int?
  goalSummary           String
  projectPlanFileName   String?
  projectPlanMimeType   String?
  projectPlanFileData   Bytes?
  projectPlanUploadedAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  reports               Report[]
  viewers               User[]       @relation("ProjectViewers")
  invitations           Invitation[]
}

model Report {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date               DateTime @db.Date
  summary            String?
  workersOnSite      Int      @default(0)
  plannedProgressPct Int?
  actualProgressPct  Int?
  completionPct      Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  workItems          ReportWorkItem[]

  @@index([date])
  @@index([projectId, date])
}

model ReportWorkItem {
  id              String @id @default(cuid())
  reportId        String
  report          Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  contractor      String
  workDescription String
  engineerName    String
  location        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([reportId])
}
